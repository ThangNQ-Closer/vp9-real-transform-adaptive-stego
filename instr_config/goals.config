# Six student-visible checkwork goals. No CW1_/CW2_ prefixes.
input_video_ready = matchany : string_equal : _input_ready : answer=True
libvpx_built = matchany : string_equal : _libvpx_built : answer=True
cover_encoded = matchany : string_equal : _cover_encoded : answer=True
stego_encoded = matchany : string_equal : _embed_bits : answer=True
receiver_verified = matchany : string_equal : _verify_success : answer=True
labtainer_outputs_ready = matchany : string_equal : _verify_metrics : answer=True
