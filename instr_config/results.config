# Native Labtainer checks use retained JSON reports after prestop cleanup.
_input_ready = sender:embed_log.json : CONTAINS : "payload": "KHOA ATTT PTIT"
_libvpx_built = sender:coeff_log.json : CONTAINS : "eligible_coeff_seen":
_cover_encoded = receiver:verify_report.json : CONTAINS : "decode_cover_ok": true
_embed_bits = sender:embed_log.json : CONTAINS : "embedded_bits": 144
_embed_modified = sender:embed_log.json : CONTAINS : "modified_coeffs":
_embed_dc_ok = sender:embed_log.json : CONTAINS : "dc_modified": 0
_embed_zero_ok = sender:embed_log.json : CONTAINS : "zero_to_nonzero": 0
_verify_success = receiver:verify_report.json : CONTAINS : "success": true
_verify_decode = receiver:verify_report.json : CONTAINS : "decode_stego_ok": true
_verify_metrics = receiver:verify_report.json : CONTAINS : "ssim":
